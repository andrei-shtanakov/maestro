{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/andrei-shtanakov/maestro/contracts/observability/evidence-ref.schema.json",
  "title": "EvidenceRef v1",
  "description": "Typed pointer to one piece of evidence about a work item (contracts roadmap phase 3, RD-003). Built on top of the keys the graduated observability contract already mints \u2014 trace_id/span_id (W3C), pipeline_id (Maestro session ULID), run_id (report_benchmark), decision_id (PolicyDecisionRef). See evidence-ref.md for kind semantics and required-key matrix. kind=gate-verdict added 2026-07-12 (WS-006 handoff M-4, pre-adoption additive).",
  "type": "object",
  "required": [
    "kind"
  ],
  "additionalProperties": false,
  "properties": {
    "kind": {
      "type": "string",
      "enum": [
        "trace",
        "log",
        "benchmark",
        "decision",
        "artifact",
        "gate-verdict"
      ],
      "description": "What the pointer refers to; drives which keys are required (see evidence-ref.md)."
    },
    "trace_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{32}$",
      "description": "W3C trace id (kind=trace: required)."
    },
    "span_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{16}$",
      "description": "W3C span id (kind=trace: optional narrowing)."
    },
    "pipeline_id": {
      "type": [
        "string",
        "null"
      ],
      "description": "Maestro session ULID = logs/<ULID>/ directory (kind=log: required)."
    },
    "run_id": {
      "type": [
        "string",
        "null"
      ],
      "description": "benchmark_runs primary key (kind=benchmark: required)."
    },
    "decision_id": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1,
      "description": "PolicyDecisionRef decision id (kind=decision: required)."
    },
    "project": {
      "type": [
        "string",
        "null"
      ],
      "description": "Owning project for kind=artifact paths."
    },
    "path": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^(?!/)(?!\\.\\.(/|$))(?!.*/\\.\\.(/|$)).+$",
      "description": "Project-relative path (kind=artifact: required). Absolute paths and `..` segments are rejected by the pattern \u2014 dereferencers must never be steered outside the owning repo."
    },
    "gate_id": {
      "type": [
        "string",
        "null"
      ],
      "description": "Gate identifier the verdict was recorded for (kind=gate-verdict: required)."
    },
    "sha": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{40}$",
      "description": "Full commit SHA the verdict is bound to (kind=gate-verdict: required; WS-006 DESIGN-608 \u2014 a new commit invalidates verdicts)."
    },
    "note": {
      "type": [
        "string",
        "null"
      ],
      "description": "Optional free-text hint for humans; never machine-parsed."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "const": "trace"
          }
        }
      },
      "then": {
        "required": [
          "kind",
          "trace_id"
        ],
        "properties": {
          "trace_id": {
            "type": "string"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "log"
          }
        }
      },
      "then": {
        "required": [
          "kind",
          "pipeline_id"
        ],
        "properties": {
          "pipeline_id": {
            "type": "string"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "benchmark"
          }
        }
      },
      "then": {
        "required": [
          "kind",
          "run_id"
        ],
        "properties": {
          "run_id": {
            "type": "string"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "decision"
          }
        }
      },
      "then": {
        "required": [
          "kind",
          "decision_id"
        ],
        "properties": {
          "decision_id": {
            "type": "integer"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "artifact"
          }
        }
      },
      "then": {
        "required": [
          "kind",
          "project",
          "path"
        ],
        "properties": {
          "project": {
            "type": "string"
          },
          "path": {
            "type": "string"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "gate-verdict"
          }
        }
      },
      "then": {
        "required": [
          "kind",
          "pipeline_id",
          "gate_id",
          "sha"
        ],
        "properties": {
          "pipeline_id": {
            "type": "string"
          },
          "gate_id": {
            "type": "string"
          },
          "sha": {
            "type": "string"
          }
        }
      }
    }
  ]
}
