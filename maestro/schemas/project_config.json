{
  "$defs": {
    "AgentType": {
      "description": "Supported agent types for task execution.",
      "enum": [
        "claude_code",
        "codex_cli",
        "aider",
        "announce",
        "opencode",
        "auto"
      ],
      "title": "AgentType",
      "type": "string"
    },
    "ArbiterConfig": {
      "additionalProperties": false,
      "description": "Configuration for the Arbiter MCP integration.\n\nValidated on YAML load. `enabled=false` (default) keeps Maestro on the\nzero-config StaticRouting path; no arbiter subprocess ever started.",
      "properties": {
        "enabled": {
          "default": false,
          "title": "Enabled",
          "type": "boolean"
        },
        "mode": {
          "$ref": "#/$defs/ArbiterMode",
          "default": "advisory"
        },
        "optional": {
          "default": false,
          "title": "Optional",
          "type": "boolean"
        },
        "binary_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Binary Path"
        },
        "config_dir": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Config Dir"
        },
        "tree_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tree Path"
        },
        "db_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Db Path"
        },
        "timeout_ms": {
          "default": 500,
          "minimum": 1,
          "title": "Timeout Ms",
          "type": "integer"
        },
        "reconnect_interval_s": {
          "default": 60,
          "minimum": 1,
          "title": "Reconnect Interval S",
          "type": "integer"
        },
        "abandon_outcome_after_s": {
          "default": 300,
          "minimum": 1,
          "title": "Abandon Outcome After S",
          "type": "integer"
        },
        "log_level": {
          "default": "warn",
          "title": "Log Level",
          "type": "string"
        }
      },
      "title": "ArbiterConfig",
      "type": "object"
    },
    "ArbiterMode": {
      "description": "Arbiter routing authority.\n\nADVISORY \u2014 explicit `agent_type` in task config is honored; arbiter is\nconsulted for learning signal and can HOLD/REJECT on invariants.\nAUTHORITATIVE \u2014 arbiter's `chosen_agent` overrides user declaration.",
      "enum": [
        "advisory",
        "authoritative"
      ],
      "title": "ArbiterMode",
      "type": "string"
    },
    "Complexity": {
      "description": "Arbiter-compatible task complexity classification.\n\nValues match `arbiter-core/src/types.rs::Complexity`. Maestro's default\ninference uses scope size as a proxy; callers can override when they\nhave richer signal (token estimates, subtask count, etc.).",
      "enum": [
        "trivial",
        "simple",
        "moderate",
        "complex",
        "critical"
      ],
      "title": "Complexity",
      "type": "string"
    },
    "DefaultsConfig": {
      "description": "Default values for task configuration.",
      "properties": {
        "timeout_minutes": {
          "default": 30,
          "description": "Default timeout in minutes",
          "maximum": 1440,
          "minimum": 1,
          "title": "Timeout Minutes",
          "type": "integer"
        },
        "max_retries": {
          "default": 2,
          "description": "Default max retries",
          "maximum": 10,
          "minimum": 0,
          "title": "Max Retries",
          "type": "integer"
        },
        "agent_type": {
          "$ref": "#/$defs/AgentType",
          "default": "claude_code",
          "description": "Default agent type"
        }
      },
      "title": "DefaultsConfig",
      "type": "object"
    },
    "GitConfig": {
      "description": "Git configuration for project.",
      "properties": {
        "base_branch": {
          "default": "main",
          "description": "Base branch name",
          "title": "Base Branch",
          "type": "string"
        },
        "auto_push": {
          "default": true,
          "description": "Automatically push after task",
          "title": "Auto Push",
          "type": "boolean"
        },
        "auto_commit": {
          "default": false,
          "description": "Auto-commit changes after each task completes",
          "title": "Auto Commit",
          "type": "boolean"
        },
        "branch_prefix": {
          "default": "agent/",
          "description": "Prefix for task branches",
          "title": "Branch Prefix",
          "type": "string"
        }
      },
      "title": "GitConfig",
      "type": "object"
    },
    "Language": {
      "description": "Arbiter-compatible primary language classification.\n\nValues match `arbiter-core/src/types.rs::Language`. `MIXED` means the\ntask spans multiple languages; `OTHER` is the fallback when inference\ncannot determine a single language.",
      "enum": [
        "python",
        "rust",
        "typescript",
        "go",
        "mixed",
        "other"
      ],
      "title": "Language",
      "type": "string"
    },
    "NotificationConfig": {
      "description": "Notification configuration.",
      "properties": {
        "desktop": {
          "default": true,
          "description": "Enable desktop notifications",
          "title": "Desktop",
          "type": "boolean"
        },
        "telegram_token": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Telegram bot token",
          "title": "Telegram Token"
        },
        "telegram_chat_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Telegram chat ID",
          "title": "Telegram Chat Id"
        },
        "webhook_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Webhook URL for notifications",
          "title": "Webhook Url"
        }
      },
      "title": "NotificationConfig",
      "type": "object"
    },
    "TaskConfig": {
      "description": "Task configuration model for YAML parsing.\n\nThis model represents a task definition as specified in the YAML config file.\nIt is used for parsing and validating task configurations before they are\nconverted to runtime Task instances.",
      "properties": {
        "id": {
          "description": "Unique task identifier",
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "title": {
          "description": "Human-readable task title",
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "prompt": {
          "description": "Task prompt for the agent",
          "minLength": 1,
          "title": "Prompt",
          "type": "string"
        },
        "agent_type": {
          "$ref": "#/$defs/AgentType",
          "default": "claude_code",
          "description": "Type of agent to execute the task"
        },
        "scope": {
          "description": "File/directory globs that the task can modify",
          "items": {
            "type": "string"
          },
          "title": "Scope",
          "type": "array"
        },
        "depends_on": {
          "description": "List of task IDs this task depends on",
          "items": {
            "type": "string"
          },
          "title": "Depends On",
          "type": "array"
        },
        "timeout_minutes": {
          "default": 30,
          "description": "Task timeout in minutes (1-1440)",
          "maximum": 1440,
          "minimum": 1,
          "title": "Timeout Minutes",
          "type": "integer"
        },
        "max_retries": {
          "default": 2,
          "description": "Maximum retry attempts (0-10)",
          "maximum": 10,
          "minimum": 0,
          "title": "Max Retries",
          "type": "integer"
        },
        "validation_cmd": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Command to validate task completion",
          "title": "Validation Cmd"
        },
        "requires_approval": {
          "default": false,
          "description": "Whether task requires manual approval before start",
          "title": "Requires Approval",
          "type": "boolean"
        },
        "priority": {
          "default": 0,
          "description": "Task priority (-100 to 100)",
          "maximum": 100,
          "minimum": -100,
          "title": "Priority",
          "type": "integer"
        },
        "task_type": {
          "anyOf": [
            {
              "$ref": "#/$defs/TaskType"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Arbiter task type. If omitted, inferred from `prompt` at Task.from_config() time."
        },
        "language": {
          "anyOf": [
            {
              "$ref": "#/$defs/Language"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Arbiter primary language. If omitted, inferred from `scope` globs at Task.from_config() time."
        },
        "complexity": {
          "anyOf": [
            {
              "$ref": "#/$defs/Complexity"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Arbiter complexity. If omitted, inferred from scope size at Task.from_config() time."
        }
      },
      "required": [
        "id",
        "title",
        "prompt"
      ],
      "title": "TaskConfig",
      "type": "object"
    },
    "TaskType": {
      "description": "Arbiter-compatible task type classification.\n\nValues match `arbiter-core/src/types.rs::TaskType` (snake_case serde).\nUsed by Arbiter's routing decision tree (ordinal feature, index 0).",
      "enum": [
        "feature",
        "bugfix",
        "refactor",
        "test",
        "docs",
        "review",
        "research"
      ],
      "title": "TaskType",
      "type": "string"
    }
  },
  "description": "Project configuration model for YAML parsing.\n\nThis is the root configuration model that represents the entire YAML\nconfiguration file including project settings, defaults, and task list.",
  "properties": {
    "project": {
      "description": "Project name",
      "minLength": 1,
      "title": "Project",
      "type": "string"
    },
    "repo": {
      "description": "Repository path",
      "minLength": 1,
      "title": "Repo",
      "type": "string"
    },
    "max_concurrent": {
      "default": 3,
      "description": "Maximum concurrent tasks (1-100)",
      "maximum": 100,
      "minimum": 1,
      "title": "Max Concurrent",
      "type": "integer"
    },
    "tasks": {
      "description": "List of task configurations",
      "items": {
        "$ref": "#/$defs/TaskConfig"
      },
      "title": "Tasks",
      "type": "array"
    },
    "defaults": {
      "anyOf": [
        {
          "$ref": "#/$defs/DefaultsConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Default values for tasks"
    },
    "git": {
      "anyOf": [
        {
          "$ref": "#/$defs/GitConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Git configuration"
    },
    "notifications": {
      "anyOf": [
        {
          "$ref": "#/$defs/NotificationConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Notification configuration"
    },
    "arbiter": {
      "anyOf": [
        {
          "$ref": "#/$defs/ArbiterConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional arbiter integration. When omitted/None the scheduler stays on zero-config StaticRouting and no subprocess is spawned."
    }
  },
  "required": [
    "project",
    "repo"
  ],
  "title": "ProjectConfig",
  "type": "object"
}
