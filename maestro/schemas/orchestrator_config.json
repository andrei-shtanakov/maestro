{
  "$defs": {
    "ArbiterConfig": {
      "additionalProperties": false,
      "description": "Configuration for the Arbiter MCP integration.\n\nValidated on YAML load. `enabled=false` (default) keeps Maestro on the\nzero-config StaticRouting path; no arbiter subprocess ever started.",
      "properties": {
        "enabled": {
          "default": false,
          "title": "Enabled",
          "type": "boolean"
        },
        "mode": {
          "$ref": "#/$defs/ArbiterMode",
          "default": "advisory"
        },
        "optional": {
          "default": false,
          "title": "Optional",
          "type": "boolean"
        },
        "binary_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Binary Path"
        },
        "config_dir": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Config Dir"
        },
        "tree_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tree Path"
        },
        "db_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Db Path"
        },
        "timeout_ms": {
          "default": 500,
          "minimum": 1,
          "title": "Timeout Ms",
          "type": "integer"
        },
        "reconnect_interval_s": {
          "default": 60,
          "minimum": 1,
          "title": "Reconnect Interval S",
          "type": "integer"
        },
        "abandon_outcome_after_s": {
          "default": 300,
          "minimum": 1,
          "title": "Abandon Outcome After S",
          "type": "integer"
        },
        "log_level": {
          "default": "warn",
          "title": "Log Level",
          "type": "string"
        }
      },
      "title": "ArbiterConfig",
      "type": "object"
    },
    "ArbiterMode": {
      "description": "Arbiter routing authority.\n\nADVISORY \u2014 explicit `agent_type` in task config is honored; arbiter is\nconsulted for learning signal and can HOLD/REJECT on invariants.\nAUTHORITATIVE \u2014 arbiter's `chosen_agent` overrides user declaration.",
      "enum": [
        "advisory",
        "authoritative"
      ],
      "title": "ArbiterMode",
      "type": "string"
    },
    "GatesConfig": {
      "additionalProperties": false,
      "description": "Gates-in-DAG guard config (WS-006 skeleton, steward DESIGN-611). Opt-in.\n\nWhen present, the orchestrator evaluates risk gates at two transition\nedges \u2014 ex-ante before READY -> RUNNING (declared workstream scope) and\nex-post before RUNNING -> MERGING (the actual diff) \u2014 by shelling out to\n``steward risk-classify`` (single source of truth for tiers; Maestro never\ncomputes risk itself). ``mode`` is fixed fail_closed: a missing or errored\nverdict on a mandatory gate blocks the transition.",
      "properties": {
        "mode": {
          "const": "fail_closed",
          "default": "fail_closed",
          "title": "Mode",
          "type": "string"
        },
        "steward_bin": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Path to the steward CLI; falls back to $MAESTRO_STEWARD_BIN",
          "title": "Steward Bin"
        },
        "risk_model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Path passed to --risk-model (default: steward's own default)",
          "title": "Risk Model"
        },
        "profile": {
          "default": "lite",
          "description": "Floor profile for risk-classify",
          "title": "Profile",
          "type": "string"
        },
        "approval_tiers": {
          "default": [
            "high",
            "critical"
          ],
          "description": "Tiers that require a human owner approval before spawn/merge",
          "items": {
            "type": "string"
          },
          "title": "Approval Tiers",
          "type": "array"
        }
      },
      "title": "GatesConfig",
      "type": "object"
    },
    "NotificationConfig": {
      "description": "Notification configuration.",
      "properties": {
        "desktop": {
          "default": true,
          "description": "Enable desktop notifications",
          "title": "Desktop",
          "type": "boolean"
        },
        "telegram_token": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Telegram bot token",
          "title": "Telegram Token"
        },
        "telegram_chat_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Telegram chat ID",
          "title": "Telegram Chat Id"
        },
        "webhook_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Webhook URL for notifications",
          "title": "Webhook Url"
        }
      },
      "title": "NotificationConfig",
      "type": "object"
    },
    "SpecRunnerConfig": {
      "description": "Configuration passed through to spec-runner.",
      "properties": {
        "max_retries": {
          "default": 3,
          "description": "Max retries per task",
          "minimum": 0,
          "title": "Max Retries",
          "type": "integer"
        },
        "task_timeout_minutes": {
          "default": 30,
          "description": "Timeout per task in minutes",
          "minimum": 1,
          "title": "Task Timeout Minutes",
          "type": "integer"
        },
        "claude_command": {
          "default": "claude",
          "description": "Claude CLI command",
          "title": "Claude Command",
          "type": "string"
        },
        "auto_commit": {
          "default": true,
          "description": "Auto-commit after task",
          "title": "Auto Commit",
          "type": "boolean"
        },
        "create_git_branch": {
          "default": true,
          "description": "Create sub-branch per task",
          "title": "Create Git Branch",
          "type": "boolean"
        },
        "run_tests_on_done": {
          "default": true,
          "description": "Run tests after task",
          "title": "Run Tests On Done",
          "type": "boolean"
        },
        "test_command": {
          "default": "uv run pytest",
          "description": "Test command to run",
          "title": "Test Command",
          "type": "string"
        },
        "lint_command": {
          "default": "uv run ruff check .",
          "description": "Lint command to run",
          "title": "Lint Command",
          "type": "string"
        },
        "run_lint_on_done": {
          "default": true,
          "description": "Run lint after task",
          "title": "Run Lint On Done",
          "type": "boolean"
        },
        "spec_gen_budget_usd": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": 1.0,
          "description": "USD cap for `spec-runner plan --full` spec generation; None disables the cap",
          "title": "Spec Gen Budget Usd"
        },
        "claude_model": {
          "default": "",
          "description": "Claude model for tasks (empty = CLI default)",
          "title": "Claude Model",
          "type": "string"
        },
        "review_command": {
          "default": "",
          "description": "Review CLI command (empty = claude_command)",
          "title": "Review Command",
          "type": "string"
        },
        "review_model": {
          "default": "",
          "description": "Review model (empty = claude_model)",
          "title": "Review Model",
          "type": "string"
        },
        "extra_executor_config": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Arbitrary overlay merged on top of the generated executor config, for ExecutorConfig fields SpecRunnerConfig doesn't mirror explicitly (e.g. personas, review_parallel, telegram_*, webhook_*, budgets). Deep-merged; keys here win over generated values.",
          "title": "Extra Executor Config"
        }
      },
      "title": "SpecRunnerConfig",
      "type": "object"
    },
    "WorkstreamConfig": {
      "description": "Configuration for a single workstream (independent work unit).\n\nUsed in YAML config or produced by auto-decomposition.",
      "properties": {
        "id": {
          "description": "Unique workstream identifier",
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "title": {
          "description": "Human-readable title",
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "description": {
          "description": "Detailed description",
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "scope": {
          "description": "File/directory globs this workstream owns",
          "items": {
            "type": "string"
          },
          "title": "Scope",
          "type": "array"
        },
        "depends_on": {
          "description": "IDs of workstreams this one depends on",
          "items": {
            "type": "string"
          },
          "title": "Depends On",
          "type": "array"
        },
        "priority": {
          "default": 0,
          "description": "Execution priority (-100 to 100)",
          "maximum": 100,
          "minimum": -100,
          "title": "Priority",
          "type": "integer"
        }
      },
      "required": [
        "id",
        "title",
        "description"
      ],
      "title": "WorkstreamConfig",
      "type": "object"
    }
  },
  "description": "Configuration for multi-process orchestration.\n\nRoot model for project.yaml configuration files.",
  "properties": {
    "project": {
      "description": "Project name",
      "minLength": 1,
      "title": "Project",
      "type": "string"
    },
    "description": {
      "default": "",
      "description": "Project description for auto-decomposition",
      "title": "Description",
      "type": "string"
    },
    "repo_url": {
      "description": "GitHub remote URL",
      "minLength": 1,
      "title": "Repo Url",
      "type": "string"
    },
    "repo_path": {
      "description": "Local repository path",
      "minLength": 1,
      "title": "Repo Path",
      "type": "string"
    },
    "workspace_base": {
      "description": "Base directory for worktrees",
      "minLength": 1,
      "title": "Workspace Base",
      "type": "string"
    },
    "max_concurrent": {
      "default": 3,
      "description": "Max concurrent workstreams (1-100)",
      "maximum": 100,
      "minimum": 1,
      "title": "Max Concurrent",
      "type": "integer"
    },
    "base_branch": {
      "default": "main",
      "description": "Base branch name",
      "title": "Base Branch",
      "type": "string"
    },
    "branch_prefix": {
      "default": "feature/",
      "description": "Prefix for workstream branches",
      "title": "Branch Prefix",
      "type": "string"
    },
    "auto_pr": {
      "default": true,
      "description": "Auto-create PR after workstream completes",
      "title": "Auto Pr",
      "type": "boolean"
    },
    "spec_runner": {
      "$ref": "#/$defs/SpecRunnerConfig",
      "description": "Spec-runner configuration"
    },
    "workstreams": {
      "description": "Manual workstreams list (auto-decompose if empty)",
      "items": {
        "$ref": "#/$defs/WorkstreamConfig"
      },
      "title": "Workstreams",
      "type": "array"
    },
    "callback_url": {
      "default": "",
      "description": "URL for spec-runner to POST task status callbacks",
      "title": "Callback Url",
      "type": "string"
    },
    "notifications": {
      "anyOf": [
        {
          "$ref": "#/$defs/NotificationConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Notification configuration"
    },
    "arbiter": {
      "anyOf": [
        {
          "$ref": "#/$defs/ArbiterConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Arbiter MCP integration config; None keeps static routing."
    },
    "gates": {
      "anyOf": [
        {
          "$ref": "#/$defs/GatesConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Gates-in-DAG guard config (WS-006); None disables gates."
    }
  },
  "required": [
    "project",
    "repo_url",
    "repo_path",
    "workspace_base"
  ],
  "title": "OrchestratorConfig",
  "type": "object"
}
